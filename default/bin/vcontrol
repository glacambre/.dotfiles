#!/bin/sh
# Control the volume

symbol="-"
if [ "$(basename "$0")" = "vup" ]; then
    symbol="+"
fi

amount="3"
if [ "$1" != "" ]; then
    amount="$1"
fi

# Try pulseaudio/pipewire first, adjusting the default sink
if command -v pactl >/dev/null 2>/dev/null; then
    if pactl get-sink-volume @DEFAULT_SINK@ >/dev/null 2>/dev/null; then
        exec pactl set-sink-volume @DEFAULT_SINK@ "${symbol}${amount}%"
    fi
fi

# Try alsa
if ! amixer -q sset Master "${amount}%${symbol}" ; then
    amixer -c 1 -q sset Master "${amount}%${symbol}"
fi
